generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  isActive  Boolean   @default(true)
  lastName  String
  role      Role      @default(USER)
  cart      Cart[]
  profile   Profile?
  purchases Purchase[]
  reports   Report?
}

model Profile {
  id        String   @id @default(uuid())
  address   String
  phone     String
  photo     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
}

model Product {
  id          String              @id @default(uuid())
  name        String
  description String
  price       Float
  stock       Int
  barcode     String
  sku         String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  isDeleted   Boolean             @default(false)
  cartLines   CartLine[]
  images      Image?
  categorys   ProductOnCategory[]
  purchases   ProductPurchase[]
}

model Image {
  id        String   @id @default(uuid())
  colection String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
}

model Category {
  id        String              @id @default(uuid())
  name      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  isDeleted Boolean             @default(false)
  products  ProductOnCategory[]
}

model ProductOnCategory {
  productId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@id([productId, categoryId])
}

model Cart {
  id          String     @id @default(uuid())
  state       State      @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isDeleted   Boolean    @default(false)
  userId      String
  totalAmount Float
  user        User       @relation(fields: [userId], references: [id])
  cartLine    CartLine[]
}

model CartLine {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)
  productId   String
  cartId      String
  quantity    Int
  total_price Float
  unit_price  Float
  cart        Cart     @relation(fields: [cartId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

model Report {
  id        String   @id @default(uuid())
  content   String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
}

model Purchase {
  id        String            @id @default(uuid())
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  isDeleted Boolean           @default(false)
  userId    String            
  products  ProductPurchase[]
  user      User              @relation(fields: [userId], references: [id])
}

model ProductPurchase {
  productId  String
  purchaseId String
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
 id        String            @id @default(uuid())
}

enum Role {
  SUPERADMIN
  USER
}

enum State {
  PENDING
  CONFIRMED
  CANCELLED
}
